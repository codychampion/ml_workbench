# MLOps Workspace Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values

# =============================================================================
# Environment Settings
# =============================================================================
MLOPS_ENV=development
DEBUG=true

# =============================================================================
# Compute Settings
# =============================================================================
COMPUTE_DEVICE=cpu
NUM_WORKERS=2

# =============================================================================
# S3-Compatible Storage (MinIO / AWS S3 / Backblaze B2)
# =============================================================================
# Local development (MinIO)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=mlops-admin
S3_SECRET_KEY=mlops-dev-password
S3_DEFAULT_BUCKET=mlops-data

# Production (uncomment and configure one):
# AWS S3:
# S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
# S3_ACCESS_KEY=your-aws-access-key
# S3_SECRET_KEY=your-aws-secret-key

# Backblaze B2:
# S3_ENDPOINT=https://s3.us-west-000.backblazeb2.com
# S3_ACCESS_KEY=your-b2-key-id
# S3_SECRET_KEY=your-b2-app-key

# =============================================================================
# FiftyOne Configuration
# =============================================================================
FIFTYONE_DATABASE_DIR=./data/fiftyone
FIFTYONE_DEFAULT_DATASET_DIR=./data/fiftyone/datasets
FIFTYONE_PORT=5151
FIFTYONE_ADDRESS=0.0.0.0

# =============================================================================
# Vault Configuration
# =============================================================================
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=mlops-dev-token

# =============================================================================
# AIM Experiment Tracking
# =============================================================================
AIM_REPO=./outputs/aim
AIM_EXPERIMENT=default

# =============================================================================
# Prefect Orchestration
# =============================================================================
PREFECT_API_URL=http://prefect:4200/api
