# MLOps Workbench - Lean Configuration
# Copy to .env and customize

# === S3 Storage (MinIO default) ===
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=mlops-admin
S3_SECRET_KEY=mlops-dev-password
S3_REGION=us-east-1
# For production: S3_ENDPOINT=https://s3.us-east-1.amazonaws.com (AWS) or https://s3.us-west-000.backblazeb2.com (B2)

# === Khoj (chat profile) ===
KHOJ_ADMIN_EMAIL=admin@mlops.local
KHOJ_ADMIN_PASSWORD=mlops-dev-password
POSTGRES_USER=mlops
POSTGRES_PASSWORD=mlops_dev_password

# === Model Provider Keys (optional, for Khoj chat) ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# === Local LLM Server (llm profile) ===
# For RTX 5090 (32GB VRAM) - tested configurations:
# - Qwen 2.5 14B: RECOMMENDED - Sweet spot, 16K context (~12GB VRAM)
# - Llama 3.1 8B: WORKS - Fast, great for MAKER, 8K context (~4GB VRAM)
# - Qwen 2.5 7B: WORKS - Excellent, 32K context (~4GB VRAM)
# - Qwen 2.5 32B: OOM with 32K context (KV cache too large)
# - Llama 3.1 70B: OOM (model too large)
LLM_MODEL=Qwen/Qwen2.5-14B-Instruct
VLLM_API_KEY=ml-workbench-key
MAX_CONTEXT=16384
GPU_MEM_UTIL=0.75
HF_CACHE_DIR=~/.cache/huggingface
HF_TOKEN=

# === AIM (tracking profile) ===
AIM_REPO=./outputs/aim

# === Jupyter (jupyter/dev profiles) ===
JUPYTER_TOKEN=mlops-dev-token

# === API (api profile) ===
# API settings configured via environment in docker-compose.yml

# === Red Team (redteam profile) ===
REDTEAM_REDIS_HOST=redis
