# MLOps Workspace .gitignore
# ==========================

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# =============================================================================
# Virtual Environments
# =============================================================================
.env
.venv
env/
venv/
ENV/

# =============================================================================
# IDE
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# =============================================================================
# Jupyter Notebooks
# =============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# =============================================================================
# Data & Outputs (Large files, generated content)
# =============================================================================
data/raw/*
data/processed/*
data/fiftyone/*
outputs/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!outputs/.gitkeep

# =============================================================================
# W&B
# =============================================================================
wandb/
outputs/wandb/

# =============================================================================
# FiftyOne
# =============================================================================
.fiftyone/

# =============================================================================
# Models (Large binary files)
# =============================================================================
*.pth
*.pt
*.onnx
*.h5
*.pkl
*.joblib
models/

# =============================================================================
# Secrets & Credentials
# =============================================================================
.env
.env.local
.env.*.local
secrets/
*.key
*.pem
credentials.json

# =============================================================================
# Docker
# =============================================================================
.docker/
comfyui_workspace/

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
Thumbs.db
*.log
*.tmp
*.temp

# =============================================================================
# Testing & Coverage
# =============================================================================
.coverage
.pytest_cache/
htmlcov/
.tox/
.nox/

# =============================================================================
# Documentation builds
# =============================================================================
docs/_build/
site/

# =============================================================================
# DVC
# =============================================================================
/data/dvc-cache/
*.dvc.lock

# =============================================================================
# Keep directories
# =============================================================================
!.gitkeep
/data/collected
