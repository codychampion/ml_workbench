#!/bin/bash
# =============================================================================
# Git Post-Merge Hook - Generate PR/Merge Summary for Knowledge Base
# =============================================================================
# This hook runs after every git merge (including PR merges via pull).
# It creates a markdown summary in the knowledge base for tracking changes.
#
# Installation:
#   ln -sf ../../hooks/post-merge .git/hooks/post-merge
#   chmod +x .git/hooks/post-merge

KNOWLEDGE_DIR="${KNOWLEDGE_DIR:-./knowledge/git-summaries}"
LITELLM_BASE="${LITELLM_API_BASE:-http://localhost:4000}"

# Create output directory
mkdir -p "$KNOWLEDGE_DIR"

# Get merge info
MERGE_COMMIT=$(git rev-parse HEAD)
MERGE_DATE=$(date +"%Y-%m-%d %H:%M:%S")
MERGE_DATE_FILE=$(date +"%Y%m%d-%H%M%S")
BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Get the commits that were merged (between HEAD^ and HEAD for most merges)
PREV_HEAD=$(git rev-parse HEAD^)

# Get changed files
CHANGED_FILES=$(git diff --name-only "$PREV_HEAD" HEAD 2>/dev/null)
NUM_FILES=$(echo "$CHANGED_FILES" | wc -l)

# Get commit messages from the merge
COMMIT_MESSAGES=$(git log --oneline "$PREV_HEAD"..HEAD 2>/dev/null | head -20)

# Get diff stats
DIFF_STATS=$(git diff --stat "$PREV_HEAD" HEAD 2>/dev/null | tail -1)

# Generate summary filename
SUMMARY_FILE="$KNOWLEDGE_DIR/${MERGE_DATE_FILE}-merge.md"

# Create the summary markdown
cat > "$SUMMARY_FILE" << EOF
---
type: git-summary
date: ${MERGE_DATE}
commit: ${MERGE_COMMIT:0:8}
branch: ${BRANCH}
tags: [git, merge, changelog]
---

# Git Merge Summary

**Date:** ${MERGE_DATE}
**Branch:** \`${BRANCH}\`
**Commit:** \`${MERGE_COMMIT:0:12}\`
**Changes:** ${DIFF_STATS}

## Commits Included

\`\`\`
${COMMIT_MESSAGES}
\`\`\`

## Files Changed

\`\`\`
${CHANGED_FILES}
\`\`\`

## Detailed Changes

EOF

# Add file-by-file summary (limited to avoid huge files)
for file in $(echo "$CHANGED_FILES" | head -10); do
    if [ -f "$file" ]; then
        ext="${file##*.}"
        echo "### \`$file\`" >> "$SUMMARY_FILE"
        echo "" >> "$SUMMARY_FILE"

        # Show diff summary for this file
        ADDITIONS=$(git diff "$PREV_HEAD" HEAD -- "$file" 2>/dev/null | grep "^+" | grep -v "^+++" | wc -l)
        DELETIONS=$(git diff "$PREV_HEAD" HEAD -- "$file" 2>/dev/null | grep "^-" | grep -v "^---" | wc -l)
        echo "+${ADDITIONS} / -${DELETIONS} lines" >> "$SUMMARY_FILE"
        echo "" >> "$SUMMARY_FILE"
    fi
done

if [ "$NUM_FILES" -gt 10 ]; then
    echo "*... and $((NUM_FILES - 10)) more files*" >> "$SUMMARY_FILE"
fi

# Add footer
cat >> "$SUMMARY_FILE" << EOF

---

## AI Summary

*To generate an AI summary, run:*
\`\`\`bash
python -m hooks.summarize_pr ${MERGE_COMMIT:0:8}
\`\`\`

---
*Auto-generated by post-merge hook on ${MERGE_DATE}*
EOF

echo "Git summary created: $SUMMARY_FILE"
