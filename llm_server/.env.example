# LLM Server Configuration

# API Security
OPENAI_API_KEY=your-secret-key-here

# HuggingFace
HF_TOKEN=  # Optional: For gated models (Llama, etc.)

# Model Selection
PRIMARY_MODEL=meta-llama/Llama-3.1-70B-Instruct
FAST_MODEL=Qwen/Qwen2.5-32B-Instruct
VISION_MODEL=Qwen/Qwen2-VL-7B-Instruct

# Performance
GPU_MEMORY_UTIL=0.9
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=128

# Paths
HF_CACHE=/root/.cache/huggingface
MODELS_DIR=./models
